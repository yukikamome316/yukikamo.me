---
import {
  card,
  cardImage,
  cardImageInner,
  cardContent,
  cardTitle,
  cardDescription,
  cardMeta,
  cardDates,
  cardDateRow,
  cardDateIcon,
  cardDateLabel,
  cardAuthor,
  cardAuthorName,
  cardSource,
  cardTagList,
  cardTag,
} from '../../styles/components/card.css';

interface Props {
  title: string;
  description?: string;
  href: string;
  date?: Date;
  updated?: Date;
  author?: string;
  tags?: string[];
  source?: string;
  external?: boolean;
  image?: string;
  imageAlt?: string;
}

const {
  title,
  description,
  href,
  date,
  updated,
  author,
  tags,
  source,
  external,
  image,
  imageAlt,
} = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
---

<a
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class={card}
>
  {
    image && (
      <div class={cardImage}>
        <img src={image} alt={imageAlt ?? title} class={cardImageInner} loading="lazy" />
      </div>
    )
  }
  <div class={cardContent}>
    <h3 class={cardTitle}>{title}</h3>
    {description && !image && <p class={cardDescription}>{description}</p>}
    <div class={cardMeta}>
      {
        date && (
          <div class={cardDates}>
            <div class={cardDateRow}>
              <span class={cardDateIcon} aria-hidden="true">📅</span>
              <span class={cardDateLabel}>公開</span>
              <time datetime={date.toISOString()}>{formatDate(date)}</time>
            </div>
            {
              updated && updated.getTime() !== date.getTime() && (
                <div class={cardDateRow}>
                  <span class={cardDateIcon} aria-hidden="true">🔄</span>
                  <span class={cardDateLabel}>更新</span>
                  <time datetime={updated.toISOString()}>{formatDate(updated)}</time>
                </div>
              )
            }
          </div>
        )
      }
      {
        author && (
          <span class={cardAuthor}>
            <span class={cardAuthorName}>@{author}</span>
          </span>
        )
      }
      {
        source && (
          <span class={cardSource}>
            {source}
            {external ? ' ↗' : ''}
          </span>
        )
      }
    </div>
    {
      tags && tags.length > 0 && (
        <div class={cardTagList}>
          {tags.map((tag) => (
            <span class={cardTag}>{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</a>
