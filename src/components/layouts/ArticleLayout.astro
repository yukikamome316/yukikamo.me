---
import {
  articleWrapper,
  articleContainer,
  articleBody,
  articleSidebar,
  toc,
  tocTitle,
  tocList,
  tocItem,
  tocItemLevel2,
  tocItemLevel3,
  tocMobile,
  tocMobileToggle,
} from "../../styles/pages/article.css";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<div class={articleWrapper}>
  <article class={articleContainer}>
    <slot name="header" />
    {
      tocHeadings.length > 0 && (
        <details class={tocMobile}>
          <summary class={tocMobileToggle}>目次</summary>
          <ol class={tocList}>
            {tocHeadings.map((heading) => (
              <li
                class={heading.depth === 3 ? tocItemLevel3 : tocItemLevel2}
              >
                <a class={tocItem} href={`#${heading.slug}`}>
                  {heading.text}
                </a>
              </li>
            ))}
          </ol>
        </details>
      )
    }
    <div class={articleBody}>
      <slot />
    </div>
  </article>

  {
    tocHeadings.length > 0 && (
      <aside class={articleSidebar}>
        <nav class={toc} aria-label="目次">
          <h2 class={tocTitle}>目次</h2>
          <ol class={tocList}>
            {tocHeadings.map((heading) => (
              <li
                class={heading.depth === 3 ? tocItemLevel3 : tocItemLevel2}
                data-heading={heading.slug}
              >
                <a class={tocItem} href={`#${heading.slug}`}>
                  {heading.text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      </aside>
    )
  }
</div>

<script is:inline>
  (() => {
    const sidebarLinks = document.querySelectorAll("[data-heading]");
    if (sidebarLinks.length === 0) return;

    const headings = [];
    let sidebar = null;

    sidebarLinks.forEach((li) => {
      const slug = li.dataset.heading;
      const el = document.getElementById(slug);
      if (el) {
        headings.push({ el, slug, li });
        if (!sidebar) {
          let parent = li.parentElement;
          while (parent && getComputedStyle(parent).overflowY !== "auto") parent = parent.parentElement;
          sidebar = parent;
        }
      }
    });
    if (headings.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const found = headings.find((h) => h.el === entry.target);
          if (!found) return;
          found.li.dataset.visible = entry.isIntersecting ? "" : undefined;
        });
        let active = null;
        for (const h of headings) {
          if (h.li.dataset.visible !== undefined) {
            active = h;
            break;
          }
        }
        sidebarLinks.forEach((li) => {
          if (active && li === active.li) {
            li.dataset.tocActive = "";
            if (li === sidebarLinks[0] && sidebar) {
              sidebar.scrollTop = 0;
            } else if (li === sidebarLinks[sidebarLinks.length - 1] && sidebar) {
              sidebar.scrollTop = sidebar.scrollHeight;
            } else {
              li.scrollIntoView({ block: "nearest", behavior: "smooth" });
            }
          } else {
            delete li.dataset.tocActive;
          }
        });
      },
      { rootMargin: "-80px 0px -60% 0px" }
    );
    headings.forEach((h) => observer.observe(h.el));
  })();
</script>
