---
import "../../styles/global.css.ts";
import "@fontsource-variable/noto-sans-jp";
import Header from "./Header.astro";
import Footer from "./Footer.astro";

import { mainContent } from "../../styles/components/layout.css.ts";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const {
  title,
  description = "Personal website of Yuki",
  image = "/ogp-default.webp",
  type = "website",
} = Astro.props;

const siteUrl = "https://yukikamo.me";
const pageUrl = siteUrl + Astro.url.pathname;
const ogImage = image.startsWith("http") ? image : "/" + image.replace(/^\//, "");
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Yuki" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <slot name="head" />
    <title>{title}</title>
  </head>
  <body>
    <div style={{ width: "100%", position: "relative" }}>
      <Header />
      <main class={mainContent}>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
