---
import "../../styles/global.css.ts";
import "@fontsource-variable/noto-sans-jp";
import "@fontsource/fira-code/400.css";
import "@fontsource/fira-code/500.css";
import "@fontsource/fira-code/700.css";
import "katex/dist/katex.min.css";
import Header from "./Header.astro";
import Footer from "./Footer.astro";

import { mainContent } from "../../styles/components/layout.css.ts";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const {
  title,
  description = "ゆきの置き手紙",
  image = "/ogp/default.webp",
  type = "website",
} = Astro.props;

const siteUrl = "https://yukikamo.me";
const pageUrl = siteUrl + Astro.url.pathname;
const ogImage = image.startsWith("http") ? image : siteUrl + image;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="ゆきの置き手紙" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <slot name="head" />
    <title>{title}</title>
  </head>
  <body>
    <div style={{ width: "100%", position: "relative" }}>
      <Header />
      <main class={mainContent}>
        <slot />
      </main>
      <Footer />
    </div>
    <script is:inline>
      document.querySelectorAll("pre").forEach((el) => {
        const check = () => {
          const tolerance = 2;
          const hasOverflow = el.scrollWidth - el.clientWidth > tolerance;
          if (hasOverflow) {
            el.dataset.scrollable = "";
            if (el.scrollLeft + el.clientWidth >= el.scrollWidth - tolerance) {
              el.dataset.scrolledEnd = "";
            } else {
              delete el.dataset.scrolledEnd;
            }
          } else {
            delete el.dataset.scrollable;
            delete el.dataset.scrolledEnd;
          }
        };
        el.addEventListener("scroll", check, { passive: true });
        window.addEventListener("resize", check, { passive: true });
        check();
      });
    </script>
  </body>
</html>
