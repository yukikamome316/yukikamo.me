---
import { header, logo, nav, navLink, navLinkActive } from '../../styles/components/header.css';

const currentPath = Astro.url.pathname;
const links = [
  { href: "/about", label: "About" },
  { href: "/work", label: "Work" },
  { href: "/blog", label: "Articles" },
];
---

<header class={header}>
  <a href="/" class={logo}>Yuki</a>
  <nav class={nav}>
    {links.map((link) => {
      const isActive = currentPath === link.href || currentPath.startsWith(`${link.href}/`);
      return (
        <a href={link.href} class={`${navLink} ${isActive ? navLinkActive : ''}`}>
          {link.label}
        </a>
      );
    })}
  </nav>
</header>
