---
import Layout from '../components/layouts/Layout.astro';
import { sectionTitle } from '../styles/pages/index.css.ts';
import {
  pageSection,
  pageTitle,
  pageDescription,
  skillsContainer,
  skillTag,
  credentialsContainer,
  credentialItem,
  credentialTitle,
  credentialOrg,
  credentialDate,
  languageGrid,
  languageItem,
  languageLevel,
  languageName,
} from '../styles/pages/about.css.ts';
import { getProfile } from '../lib/profile';

const { bio, credentials, skills, languages } = getProfile();
---

<Layout title="About | Yuki" description={bio}>
  <section class={pageSection}>
    <h1 class={pageTitle}>About Me</h1>
    <p class={pageDescription}>{bio}</p>

    <!-- 資格 -->
    <h2 class={sectionTitle}>Credentials</h2>
    <div class={credentialsContainer}>
      {credentials.map((c) => (
        <div class={credentialItem}>
          <span class={credentialTitle}>{c.title}</span>
          <span class={credentialOrg}>{c.issuer}</span>
          {c.issuedLabel && <span class={credentialDate}>{c.issuedLabel}</span>}
        </div>
      ))}
    </div>

    <!-- スキル -->
    <h2 class={sectionTitle}>Skills</h2>
    <div class={skillsContainer}>
      {skills.map((skill) => (
        <span class={skillTag}>{skill}</span>
      ))}
    </div>

    <!-- 言語 -->
    <h2 class={sectionTitle}>Languages</h2>
    <div class={languageGrid}>
      {languages.map((lang) => (
        <div class={languageItem}>
          <span class={languageName}>{lang.name}</span>
          <span class={languageLevel}>{lang.proficiencyLabel}</span>
        </div>
      ))}
    </div>
  </section>
</Layout>
