---
import { getCollection } from 'astro:content';
import Layout from '../../components/layouts/Layout.astro';
import ArticleLayout from '../../components/layouts/ArticleLayout.astro';
import ShareButtons from '../../components/features/ShareButtons.tsx';
import {
  articleHeader,
  articleMeta,
  articleMetaItem,
  articleMetaLabel,
  articleMetaValue,
  articleTitle,
  articleTagList,
  articleTag,
} from '../../styles/pages/article.css';

export async function getStaticPaths() {
  const blogEntries = (await getCollection('blog')).filter(e => !e.data.draft);
  const sortedEntries = blogEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return sortedEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const { slug } = entry;

const formatDate = (date: Date) =>
  date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });

const readingTime = Math.max(1, Math.ceil((entry.body?.length ?? 0) / 600));

const siteUrl = 'https://yukikamo.me';
const pageUrl = `${siteUrl}/articles/${slug}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.description,
  url: pageUrl,
  datePublished: entry.data.date.toISOString(),
  ...(entry.data.updated && { dateModified: entry.data.updated.toISOString() }),
  author: {
    '@type': 'Person',
    name: 'Yuki',
    url: siteUrl,
  },
};
---

<Layout
  title={`${entry.data.title} | Articles`}
  description={entry.data.description}
  type="article"
  image={`/ogp/articles/${slug}.webp`}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <ArticleLayout headings={headings}>
    <header slot="header" class={articleHeader}>
      <div class={articleMeta}>
        <div class={articleMetaItem}>
          <span class={articleMetaLabel}>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            公開日
          </span>
          <time class={articleMetaValue} datetime={entry.data.date.toISOString()}>
            {formatDate(entry.data.date)}
          </time>
        </div>
        {
          entry.data.updated && (
            <div class={articleMetaItem}>
              <span class={articleMetaLabel}>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 4v6h6"/><path d="M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
                更新日
              </span>
              <time class={articleMetaValue} datetime={entry.data.updated.toISOString()}>
                {formatDate(entry.data.updated)}
              </time>
            </div>
          )
        }
        <div class={articleMetaItem}>
          <span class={articleMetaLabel}>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            読了時間
          </span>
          <span class={articleMetaValue}>約{readingTime}分 ({entry.body?.length ?? 0}文字)</span>
        </div>
      </div>
      <h1 class={articleTitle}>{entry.data.title}</h1>
      <div class={articleTagList}>
        {entry.data.tags?.map((tag: string) => <span class={articleTag}>#{tag}</span>)}
      </div>
    </header>

    <Content />
    <slot name="footer" />
  </ArticleLayout>

  <ShareButtons url={pageUrl} title={entry.data.title} client:load />
</Layout>
