---
import Layout from "../components/layouts/Layout.astro";
import HeroCardSwap from "../components/features/HeroCardSwap.tsx";
import {
  heroContainer,
  heroProfileContainer,
  heroTextContainer,
  heroVisualContainer,
  profileImage,
  heroTitleWrapper,
  heroTitle,
  heroSubtitle,
  heroDescription,
  sectionTitle,
  workSection,
  blogSection,
} from "../styles/pages/index.css.ts";
import { grid } from "../styles/components/card.css.ts";
import Card from "../components/ui/Card.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { extractHeadings } from "../lib/post-head";
import { getExternalPosts } from "../lib/external-posts";

import imgSusukino from "../assets/hero/susukino.webp";
import imgMarunouchi from "../assets/hero/marunouchi.webp";
import imgMatsuda from "../assets/hero/matsuda.webp";
import imgAlps from "../assets/hero/the-northern-japan-alps.webp";
import profileImg from "../assets/profile.webp";

const heroCards = [
  { title: "Susukino", src: imgSusukino.src },
  { title: "Marunouchi", src: imgMarunouchi.src },
  { title: "Matsuda", src: imgMatsuda.src },
  { title: "The Northern Japan Alps", src: imgAlps.src },
];

const allWork = await getCollection("work");
const recentWork = allWork
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const allBlog = await getCollection("blog");
const externalPosts = getExternalPosts();

const allPosts = [
  ...allBlog.map((post) => ({
    type: "internal" as const,
    title: post.data.title,
    href: `/blog/${post.slug}`,
    date: post.data.date,
    updated: post.data.updated,
    tags: post.data.tags,
    author: "Yuki",
    image: `/ogp/blog/${post.slug}.webp`,
    head: extractHeadings(post.body),
  })),
  ...externalPosts.map((post) => ({
    type: "external" as const,
    title: post.title,
    href: post.url,
    date: post.date,
    updated: undefined as Date | undefined,
    tags: post.tags,
    source: post.source,
    author: post.source,
    image: undefined as string | undefined,
    head: post.head,
  })),
];

const recentPosts = allPosts
  .sort((a, b) => b.date.valueOf() - a.date.valueOf())
  .slice(0, 3);
---

<Layout title="ゆきの置き手紙" description="ゆきの置き手紙 - ゆきの個人サイト。IT と旅行が好きなセキュリティエンジニア。">
  <Fragment slot="head">
    <link
      rel="preload"
      href={profileImg.src}
      as="image"
      type="image/webp"
      fetchpriority="high"
    />
    <link
      rel="preload"
      href={imgSusukino.src}
      as="image"
      type="image/webp"
      fetchpriority="high"
    />
  </Fragment>

  <!-- Hero Section -->
  <section class={heroContainer}>
    <div class={heroTextContainer}>
      <div class={heroProfileContainer}>
        <Image
          src={profileImg}
          alt="yukikamome316"
          class={profileImage}
          width={140}
          height={140}
          loading="eager"
          fetchpriority="high"
        />
        <div class={heroTitleWrapper}>
          <h1 class={heroTitle}>Yuki</h1>
          <p class={heroSubtitle}>@yukikamome316</p>
        </div>
      </div>
      <p class={heroDescription}>
        ゆきです👋 IT と旅行が好きなセキュリティエンジニアです。Web
        開発やアルゴリズム最適化など幅広く学んでいますが、アウトドア派なので車や飛行機などで遠出することも多いです。気になる場所があればどこへでも行きます。
      </p>
    </div>
    <div class={heroVisualContainer}>
      <HeroCardSwap client:idle cards={heroCards} />
    </div>
  </section>

  <!-- Work Section -->
  <section class={workSection}>
    <h2 class={sectionTitle}>Selected Work</h2>
    <div class={grid}>
      {
        recentWork.map((work) => (
          <Card
            title={work.data.title}
            description={work.data.description}
            href={`/work/${work.slug}`}
          />
        ))
      }
    </div>
  </section>

  <!-- Blog Section -->
  <section class={blogSection}>
    <h2 class={sectionTitle}>Latest Posts</h2>
    <div class={grid}>
      {
        recentPosts.map((post) => (
          <Card
            title={post.title}
            href={post.href}
            date={post.date}
            updated={post.updated}
            tags={post.tags}
            author={post.author}
            image={post.image}
            head={post.head}
            source={post.type === "external" ? post.source : undefined}
            external={post.type === "external"}
          />
        ))
      }
    </div>
  </section>
</Layout>
