---
import Layout from '../components/layouts/Layout.astro';
import HeroCardSwap from '../components/features/HeroCardSwap.tsx';
import { heroContainer, heroTextContainer, profileImage, heroTitleWrapper, heroTitle, heroSubtitle, heroDescription, sectionTitle } from '../styles/pages/index.css.ts';
import { grid } from '../styles/components/card.css.ts';
import Card from '../components/ui/Card.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

import imgSusukino from '../assets/hero/susukino.webp';
import imgMarunouchi from '../assets/hero/marunouchi.webp';
import imgMatsuda from '../assets/hero/matsuda.webp';
import imgAlps from '../assets/hero/the-northern-japan-alps.webp';
import profileImg from '../assets/profile.webp';

const heroCards = [
  { title: "Susukino", src: imgSusukino.src },
  { title: "Marunouchi", src: imgMarunouchi.src },
  { title: "Matsuda", src: imgMatsuda.src },
  { title: "The Northern Japan Alps", src: imgAlps.src },
];

const allWork = await getCollection('work');
const recentWork = allWork.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);

const allBlog = await getCollection('blog');
const recentBlog = allBlog.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
---

<Layout title="Yuki - Portfolio & Blog">
  <Fragment slot="head">
    <link rel="preload" href={profileImg.src} as="image" type="image/webp" fetchpriority="high" />
    <link rel="preload" href={imgSusukino.src} as="image" type="image/webp" fetchpriority="high" />
  </Fragment>

  <!-- Hero Section -->
  <section class={heroContainer}>
    <div class={heroTextContainer}>
      <div style={{ display: 'flex', alignItems: 'center', gap: '1.5rem', marginBottom: '1rem' }}>
        <Image src={profileImg} alt="Yukikamome316" class={profileImage} width={140} height={140} loading="eager" fetchpriority="high" style={{ borderRadius: '50%', objectFit: 'cover', margin: 0 }} />
        <div class={heroTitleWrapper} style={{ display: 'flex', flexDirection: 'column', justifyContent: 'center' }}>
          <h1 class={heroTitle}>Yuki</h1>
          <p class={heroSubtitle}>@yukikamome316</p>
        </div>
      </div>
      <p class={heroDescription}>
        <!-- Crafting digital experiences with a focus on web development, design, and performance. Building fast, accessible, and beautiful interfaces for the modern web. -->
        ゆきです👋 IT と旅行が好きなセキュリティエンジニアです。Web 開発やアルゴリズム最適化など幅広く学んでいますが、アウトドア派なので車や飛行機などで遠出することも多いです。気になる場所があればどこへでも行きます。
      </p>
    </div>
    <div style={{ flex: 1, display: 'flex', justifyContent: 'flex-end', position: 'relative', minWidth: '300px' }}>
      <HeroCardSwap client:idle cards={heroCards} />
    </div>
  </section>

  <!-- Work Section -->
  <section style={{ marginTop: '4rem' }}>
    <h2 class={sectionTitle}>Selected Work</h2>
    <div class={grid}>
      {recentWork.map(work => (
        <Card title={work.data.title} description={work.data.description} href={`/work/${work.slug}`} />
      ))}
    </div>
  </section>

  <!-- Blog Section -->
  <section style={{ marginTop: '4rem', marginBottom: '4rem' }}>
    <h2 class={sectionTitle}>Latest Posts</h2>
    <div class={grid}>
      {recentBlog.map(post => (
        <Card title={post.data.title} description={post.data.description || ''} href={`/blog/${post.slug}`} />
      ))}
    </div>
  </section>
</Layout>
