---
import Layout from '../../components/layouts/Layout.astro';
import Card from '../../components/ui/Card.astro';
import { getCollection } from 'astro:content';
import { grid } from '../../styles/components/card.css';
import { listSection, listTitle, listDescription } from '../../styles/pages/list.css';

const workEntries = await getCollection('work');
const sortedEntries = workEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Work | Yuki" description="A collection of projects I've built or contributed to.">
  <section class={listSection}>
    <h1 class={listTitle}>Selected Work</h1>
    <p class={listDescription}>A collection of projects I've built or contributed to.</p>
    
    <div class={grid}>
      {sortedEntries.map(entry => (
        <Card 
          title={entry.data.title} 
          description={entry.data.description} 
          href={`/work/${entry.slug}`} 
        />
      ))}
    </div>
  </section>
</Layout>
