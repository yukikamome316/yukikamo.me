---
import { getCollection } from 'astro:content';
import Layout from '../../components/layouts/Layout.astro';
import { vars } from '../../styles/theme.css.ts';


export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const dateString = entry.data.date.toLocaleDateString('ja-JP', { 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});
---

<Layout title={`${entry.data.title} | Blog`}>
  <article style={{ marginTop: '4rem', marginBottom: '6rem', maxWidth: '800px', margin: '4rem auto 6rem' }}>
    <header style={{ marginBottom: '3rem' }}>
      <time style={{ color: vars.color.muted, fontSize: '0.875rem' }}>{dateString}</time>
      <h1 style={{ fontSize: '2.5rem', marginTop: '0.5rem', marginBottom: '1rem' }}>{entry.data.title}</h1>
      <div style={{ display: 'flex', gap: '0.5rem' }}>
        {entry.data.tags?.map((tag: string) => (
          <span style={{ fontSize: '0.875rem', color: vars.color.primary }}>#{tag}</span>
        ))}
      </div>
    </header>
    
    <div class="prose" style={{ lineHeight: 1.8, fontSize: '1.125rem' }}>
      <Content />
    </div>
  </article>
</Layout>

<style is:global>
  /* Markdown 内のタグ用スタイル補正 */
  .prose h1, .prose h2, .prose h3 {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose p {
    margin-bottom: 1.5rem;
  }
  .prose ul, .prose ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  .prose li {
    margin-bottom: 0.5rem;
  }
  .prose code {
    background: #f5f7fa;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.875em;
  }
</style>
