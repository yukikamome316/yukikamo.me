---
import { getCollection } from 'astro:content';
import Layout from '../../components/layouts/Layout.astro';
import { articleContainer, articleHeader, articleDate, articleTitle, articleTagList, articleTag, articleBody } from '../../styles/pages/article.css';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { slug } = entry;

const dateString = entry.data.date.toLocaleDateString('ja-JP', { 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});
---

<Layout title={`${entry.data.title} | Blog`} description={entry.data.description} type="article" image={`/ogp/blog/${slug}.webp`}>
  <article class={articleContainer}>
    <header class={articleHeader}>
      <time class={articleDate}>{dateString}</time>
      <h1 class={articleTitle}>{entry.data.title}</h1>
      <div class={articleTagList}>
        {entry.data.tags?.map((tag: string) => (
          <span class={articleTag}>#{tag}</span>
        ))}
      </div>
    </header>
    
    <div class={articleBody}>
      <Content />
    </div>
  </article>
</Layout>
