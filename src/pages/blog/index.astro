---
import Layout from '../../components/layouts/Layout.astro';
import Card from '../../components/ui/Card.astro';
import { getCollection } from 'astro:content';
import { getExternalPosts } from '../../lib/external-posts';
import { extractExcerpt, extractHeadings } from '../../lib/post-head';
import { grid } from '../../styles/components/card.css';
import { listSection, listTitle, listDescription } from '../../styles/pages/list.css';

const blogEntries = await getCollection('blog');

const internalPosts = blogEntries.map((entry) => ({
  type: 'internal' as const,
  title: entry.data.title,
  href: `/blog/${entry.slug}`,
  date: entry.data.date,
  updated: entry.data.updated,
  tags: entry.data.tags,
  image: `/ogp/blog/${entry.slug}.webp`,
  excerpt: extractExcerpt(entry.body),
  head: extractHeadings(entry.body),
}));

const externalPosts = getExternalPosts();

const allPosts = [
  ...internalPosts,
  ...externalPosts.map((post) => ({
    type: 'external' as const,
    title: post.title,
    href: post.url,
    date: post.date,
    updated: undefined as Date | undefined,
    tags: post.tags,
    source: post.source,
    image: post.image,
    excerpt: undefined as string | undefined,
    head: post.head,
  })),
];

const sortedPosts = allPosts.sort((a, b) => b.date.valueOf() - a.date.valueOf());
---

<Layout title="Blog | Yuki" description="ソフトウェアエンジニアリング、セキュリティ、日々のことについて書いています。">
  <section class={listSection}>
    <h1 class={listTitle}>Blog</h1>
    <p class={listDescription}>ソフトウェアエンジニアリング、セキュリティ、日々のことについて書いています。</p>

    <div class={grid}>
      {
        sortedPosts.map((post) => (
          <Card
            title={post.title}
            description={post.description}
            href={post.href}
            date={post.date}
            tags={post.tags}
            image={post.image}
            excerpt={post.excerpt}
            head={post.head}
            source={post.type === 'external' ? post.source : undefined}
            external={post.type === 'external'}
          />
        ))
      }
    </div>
  </section>
</Layout>
