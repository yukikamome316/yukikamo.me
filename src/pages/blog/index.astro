---
import Layout from '../../components/layouts/Layout.astro';
import Card from '../../components/ui/Card.astro';
import { getCollection } from 'astro:content';
import { grid } from '../../styles/components/card.css';
import { listSection, listTitle, listDescription } from '../../styles/pages/list.css';

const blogEntries = await getCollection('blog');
const sortedEntries = blogEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Articles | ゆきの置き手紙" description="ゆきの置き手紙 - ゆきのブログ。ソフトウェアエンジニアリング、セキュリティ、日常について。">
  <section class={listSection}>
    <h1 class={listTitle}>Articles</h1>
    <p class={listDescription}>ソフトウェアエンジニアリング、セキュリティ、日常について。</p>
    
    <div class={grid}>
      {sortedEntries.map(entry => (
        <Card 
          title={entry.data.title} 
          description={entry.data.description || ''} 
          href={`/blog/${entry.slug}`} 
        />
      ))}
    </div>
  </section>
</Layout>
