---
import Layout from '../../components/layouts/Layout.astro';
import Card from '../../components/ui/Card.astro';
import { getCollection } from 'astro:content';
import { grid } from '../../styles/components/card.css';
import { listSection, listTitle, listDescription } from '../../styles/pages/list.css';

const blogEntries = await getCollection('blog');
const sortedEntries = blogEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog | Yuki" description="Thoughts on software engineering, security, and life.">
  <section class={listSection}>
    <h1 class={listTitle}>Blog</h1>
    <p class={listDescription}>Thoughts on software engineering, design, and life.</p>
    
    <div class={grid}>
      {sortedEntries.map(entry => (
        <Card 
          title={entry.data.title} 
          description={entry.data.description || ''} 
          href={`/blog/${entry.slug}`} 
        />
      ))}
    </div>
  </section>
</Layout>
