---
import Layout from '../../components/layouts/Layout.astro';
import Card from '../../components/ui/Card.astro';
import { getCollection } from 'astro:content';
import { getExternalPosts } from '../../lib/external-posts';
import { grid } from '../../styles/components/card.css';
import {
  listSection,
  listTitle,
  listDescription,
  yearGroup,
  yearGroupTitle,
} from '../../styles/pages/list.css';

const blogEntries = await getCollection('blog');
const externalPosts = getExternalPosts();

const allPosts = [
  ...blogEntries.map((entry) => ({
    type: 'internal' as const,
    title: entry.data.title,
    description: entry.data.description || '',
    href: `/blog/${entry.slug}`,
    date: entry.data.date,
    tags: entry.data.tags,
  })),
  ...externalPosts.map((post) => ({
    type: 'external' as const,
    title: post.title,
    description: post.description || '',
    href: post.url,
    date: post.date,
    tags: post.tags,
    source: post.source,
  })),
];

const sortedPosts = allPosts.sort((a, b) => b.date.valueOf() - a.date.valueOf());

const groupedByYear = sortedPosts.reduce<Record<number, typeof sortedPosts>>((acc, post) => {
  const year = post.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(groupedByYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<Layout title="Blog | Yuki" description="ソフトウェアエンジニアリング、セキュリティ、日々のことについて書いています。">
  <section class={listSection}>
    <h1 class={listTitle}>Blog</h1>
    <p class={listDescription}>ソフトウェアエンジニアリング、セキュリティ、日々のことについて書いています。</p>

    {
      years.map((year) => (
        <div class={yearGroup}>
          <h2 class={yearGroupTitle}>{year}</h2>
          <div class={grid}>
            {groupedByYear[year].map((post) => (
              <Card
                title={post.title}
                description={post.description}
                href={post.href}
                date={post.date}
                tags={post.tags}
                source={post.type === 'external' ? post.source : undefined}
                external={post.type === 'external'}
              />
            ))}
          </div>
        </div>
      ))
    }
  </section>
</Layout>
